# Supabase — required for cross-device sync (same project as Wellness Tracker)
# Get these from: supabase.com → your project → Settings → API
#
# Email OTP: Magic link template must include {{ .Token }} — see CLAUDE.md / Wellness CLAUDE.md.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
REACT_APP_AUTH_CANONICAL_ORIGIN=https://apps.chasewhittaker.com
REACT_APP_AUTH_APP_PATH=/job-search
REACT_APP_SUPABASE_STORAGE_KEY=chase_portfolio_auth_token
REACT_APP_AUTH_DEBUG=true

# ── Gmail Inbox Feed (v8.18) ──────────────────────────────────────────────
# Browser-side: client_id only (safe to expose)
REACT_APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Server-only — set in Vercel via `vercel env add` for production + preview.
# Never prefix these with REACT_APP_ (would leak into the browser bundle).
#   GOOGLE_CLIENT_SECRET            — from GCP OAuth client (Web app type)
#   GMAIL_TOKEN_ENC_KEY             — 32-byte AES key, base64-encoded:
#                                       openssl rand -base64 32
#   SUPABASE_SERVICE_ROLE_KEY       — Supabase Settings → API → service_role
GOOGLE_CLIENT_SECRET=
GMAIL_TOKEN_ENC_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then install the Supabase client:
#   npm install @supabase/supabase-js
#
# Then follow the wiring steps in /portfolio/shared/sync.js
#
# v8.6+: No Anthropic key in-app — use Apply Tools copy prompts with an external assistant.
