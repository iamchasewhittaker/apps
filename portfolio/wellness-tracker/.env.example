# Supabase — required for cross-device sync
# Get these from: supabase.com → your project → Settings → API
#
# Email sign-in codes: Dashboard → Authentication → Email Templates → Magic link
# must include {{ .Token }} in the body (default template is link-only). See CLAUDE.md.
#
# NOTE: This is Create React App (react-scripts), so env vars MUST be prefixed
# with REACT_APP_ to be included in the build. VITE_ prefix does NOT work here.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
REACT_APP_AUTH_CANONICAL_ORIGIN=https://apps.chasewhittaker.com
REACT_APP_AUTH_APP_PATH=/wellness
REACT_APP_SUPABASE_STORAGE_KEY=chase_portfolio_auth_token
REACT_APP_AUTH_DEBUG=true

# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then install the Supabase client:
#   npm install @supabase/supabase-js
#
# Restart the dev server after editing .env (CRA does not hot-reload env changes).
