NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only; Supabase dashboard → project settings → API
CRON_SECRET=                 # openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=        # openssl rand -base64 32, used by lib/crypto.ts
AI_GATEWAY_API_KEY=          # Vercel AI Gateway — used by lib/ai/gateway.ts (default openai/gpt-4o-mini). After `vercel env pull production`, the value is often empty locally; run `pnpm run env:pull-local` to merge production + development so this key is filled for `pnpm dev`.
