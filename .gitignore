# Monorepo root: ~/Developer/chase — only these top-level trees are version-controlled.
/*
!.gitignore
!/MONOREPO_MIGRATION.md
!/HANDOFF.md
!/docs/
!/docs/**
!/CLAUDE.md
!/ROADMAP.md
!/SUNSAMA_MCP_GUIDE.md
!/PRODUCT_BUILD_FRAMEWORK.md
!/.claude/
!/.claude/**
!/.cursor/
!/.cursor/rules/
!/.cursor/rules/**
!/portfolio/
!/portfolio/**
!/projects/
!/projects/**
!/scripts/
!/scripts/**
!/.github/
!/.github/workflows/
!/.github/workflows/**

# Dependencies & build output (all subtrees)
node_modules/
dist/
build/

# Secrets & local env
.env
.env.local
.env.*.local

# OS & tooling
.DS_Store
**/.DS_Store
*.log
.vercel
**/.claude/settings.local.json

# Supabase CLI local temp
**/supabase/.temp/

# Raw statement exports — keep local; do not publish to git hosts
# (projects/Money removed — see portfolio/archive/money/)
# YNAB / Gmail integration secrets now live in portfolio/spend-clarity/config/ (gitignored by that app's .gitignore)

